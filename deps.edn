{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc → portable to JVM / SCI / ClojureScript / GraalVM). Same runtime
 ;; the robotaxi-actor rides on; a vehicle DESIGN is just another StateGraph.
 :deps {io.github.kotoba-lang/langgraph  {:git/url "https://github.com/kotoba-lang/langgraph.git"
                                          :sha "5b4e5e70837b849b14b6a5800894e3be202ad5fa"}
        ;; shared, purpose-split libraries (commonized out of this actor)
        io.github.kotoba-lang/datom       {:git/url "https://github.com/kotoba-lang/datom.git"
                                           :sha "d27a5833d59d909367956705f2ec931399c891ee"}
        io.github.kotoba-lang/kami-engine-vphysics
        {:git/url "https://github.com/kotoba-lang/kami-engine-vphysics.git"
         :git/sha "f6b5936c5009b61c681f7926a0ab10c0030841b6"}
        io.github.kotoba-lang/physics
        {:git/url "https://github.com/kotoba-lang/physics.git"
         :git/sha "3081560a4327319d9916a3c1c53471223462c0c3"}
        ;; CAE seeds — computed values injected into the design loop (#2/#3):
        ;;   aero  → Cd (range), crash → structural SF (simverify),
        ;;   echem → FCEV stack efficiency (H2 consumption)
        io.github.kotoba-lang/kami-engine-aero        {:git/url "https://github.com/kotoba-lang/kami-engine-aero.git"
                                           :sha "7151ae056b8dcd8338c9717d932e347c1817ba66"}
        io.github.kotoba-lang/kami-engine-crash       {:git/url "https://github.com/kotoba-lang/kami-engine-crash.git"
                                           :sha "fa29f4e0282c5ab00741084dc9492b5fe76e5b1a"}
        io.github.kotoba-lang/kami-engine-echem       {:git/url "https://github.com/kotoba-lang/kami-engine-echem.git"
                                           :sha "2a6b330a876515c8625bac70edd44a6dc8960c6e"}
        io.github.kotoba-lang/kami-engine-motor       {:git/url "https://github.com/kotoba-lang/kami-engine-motor.git"
                                           :sha "d49a16e7563ef230531b3b0c7f3152f5f9d2ce8c"}
        ;; CAD/CAM bridge (vdesign.cad / vdesign.process): org-iso-10303
        ;; (renamed from brep) = BREP kernel + STEP I/O, org-iso-6983
        ;; (renamed from cnc) = real toolpath/G-code engine, cad =
        ;; kotoba-lang's artifact-registry/maturity-scoring layer (NOT a
        ;; geometry kernel despite the name; see vdesign.cad docstring)
        io.github.kotoba-lang/org-iso-10303 {:git/url "https://github.com/kotoba-lang/org-iso-10303.git"
                                             :sha "36d50ebe65d07e4ba5714388c8863e7dfa98becc"}
        io.github.kotoba-lang/org-iso-6983  {:git/url "https://github.com/kotoba-lang/org-iso-6983.git"
                                             :sha "e1998926e70c3707b2dcb751df0f1380dd86c0bc"}
        io.github.kotoba-lang/cad  {:git/url "https://github.com/kotoba-lang/cad.git"
                                    :sha "8473733293c090e6509f6cb30a5890661d279e40"}
        ;; Real time-stepped 2D rigid-body physics (vdesign.simphysics,
        ;; ADR-2607151600) — a genuine, tested impulse-based solver restored
        ;; 1:1 from the deleted kami-physics-2d Rust crate, NOT a new engine
        ;; written for this actor.
        io.github.kotoba-lang/physics-2d {:git/url "https://github.com/kotoba-lang/physics-2d.git"
                                          :sha "03b6c23c8d9aa36b92a8130fd3e37fc2548b4d26"}}
 :aliases
 {;; offline workspace dev — pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain {:local/root "../langchain"}}}
  ;; clojure -M:dev:run  → clean-sheet a BEV and an FCEV from one spec, compare
  :run {:main-opts ["-m" "vdesign.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
