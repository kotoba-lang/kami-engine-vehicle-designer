{:paths ["src"]
 ;; langgraph-clj brings langchain-clj transitively (both zero-/single-dep,
 ;; all .cljc → portable to JVM / SCI / ClojureScript / GraalVM). Same runtime
 ;; the robotaxi-actor rides on; a vehicle DESIGN is just another StateGraph.
 :deps {io.github.com-junkawasaki/langgraph-clj  {:local/root "../langgraph-clj"}
        ;; shared, purpose-split libraries (commonized out of this actor)
        io.github.com-junkawasaki/datom-clj       {:local/root "../datom-clj"}
        io.github.com-junkawasaki/vphysics-clj    {:local/root "../vphysics-clj"}
        ;; CAE seeds — computed values injected into the design loop (#2/#3):
        ;;   aero  → Cd (range), crash → structural SF (simverify),
        ;;   echem → FCEV stack efficiency (H2 consumption)
        io.github.com-junkawasaki/aero-clj        {:local/root "../aero-clj"}
        io.github.com-junkawasaki/crash-clj       {:local/root "../crash-clj"}
        io.github.com-junkawasaki/echem-clj       {:local/root "../echem-clj"}}
 :aliases
 {;; offline workspace dev — pin transitive langchain-clj to local checkout
  :dev {:override-deps
        {io.github.com-junkawasaki/langchain-clj {:local/root "../langchain-clj"}}}
  ;; clojure -M:dev:run  → clean-sheet a BEV and an FCEV from one spec, compare
  :run {:main-opts ["-m" "vdesign.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
