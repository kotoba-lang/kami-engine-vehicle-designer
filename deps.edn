{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc → portable to JVM / SCI / ClojureScript / GraalVM). Same runtime
 ;; the robotaxi-actor rides on; a vehicle DESIGN is just another StateGraph.
 :deps {io.github.kotoba-lang/langgraph  {:git/url "https://github.com/kotoba-lang/langgraph.git"
                                          :sha "5b4e5e70837b849b14b6a5800894e3be202ad5fa"}
        ;; shared, purpose-split libraries (commonized out of this actor)
        io.github.kotoba-lang/datom       {:git/url "https://github.com/kotoba-lang/datom.git"
                                           :sha "d27a5833d59d909367956705f2ec931399c891ee"}
        io.github.kotoba-lang/vphysics    {:git/url "https://github.com/kotoba-lang/vphysics.git"
                                           :sha "32c2329ed6bd1074b2d0d3dab17f3440477cbbc3"}
        ;; CAE seeds — computed values injected into the design loop (#2/#3):
        ;;   aero  → Cd (range), crash → structural SF (simverify),
        ;;   echem → FCEV stack efficiency (H2 consumption)
        io.github.kotoba-lang/aero        {:git/url "https://github.com/kotoba-lang/aero.git"
                                           :sha "7151ae056b8dcd8338c9717d932e347c1817ba66"}
        io.github.kotoba-lang/crash       {:git/url "https://github.com/kotoba-lang/crash.git"
                                           :sha "fa29f4e0282c5ab00741084dc9492b5fe76e5b1a"}
        io.github.kotoba-lang/echem       {:git/url "https://github.com/kotoba-lang/echem.git"
                                           :sha "2a6b330a876515c8625bac70edd44a6dc8960c6e"}
        io.github.kotoba-lang/motor       {:git/url "https://github.com/kotoba-lang/motor.git"
                                           :sha "d49a16e7563ef230531b3b0c7f3152f5f9d2ce8c"}}
 :aliases
 {;; offline workspace dev — pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain {:local/root "../langchain"}}}
  ;; clojure -M:dev:run  → clean-sheet a BEV and an FCEV from one spec, compare
  :run {:main-opts ["-m" "vdesign.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
